APP_NAME=Nexus
APP_ENV=local # production | staging | development | local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=nexus

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
REDIS_HOST=cache
REDIS_PORT=6379
# CACHE_PREFIX=


AUTH_PUBLIC_KEY_PATH=oauth-public.key
AUTH_PRIVATE_KEY_PATH=oauth-private.key
